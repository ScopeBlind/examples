{
  "name": "scopeblind-express-example",
  "version": "1.0.0",
  "private": true,
  "description": "Express MCP server wrapped with protect-mcp policies and signed receipts",
  "type": "module",
  "scripts": {
    "start": "npx protect-mcp --policy policy.json --enforce -- node server.js",
    "start:shadow": "npx protect-mcp --policy policy.json -- node server.js",
    "test": "./test.sh",
    "receipts": "npx protect-mcp receipts",
    "verify": "npx @veritasacta/verify .protect-mcp-receipts.jsonl",
    "bundle": "npx protect-mcp bundle"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.0"
  }
}
